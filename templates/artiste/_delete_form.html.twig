<form method="post" action="{{ path('app_artiste_delete', {'id': artiste.id}) }}"
      data-turbo="false"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet artiste ?');">

    {# Token CSRF pour sécuriser la suppression #}
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ artiste.id) }}">

    <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer">
        Supprimer
    </button>

</form>
