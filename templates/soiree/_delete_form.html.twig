<form method="post" action="{{ path('app_soiree_delete', {'id': soiree.id}) }}" 
      data-turbo="false"
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette soirée ?');">
    
    {# Token CSRF pour sécuriser la suppression #}
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ soiree.id) }}">
    
    <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer">
        Supprimer
    </button>
</form>