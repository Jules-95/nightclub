{% extends 'base.html.twig' %}

{% block title %}Soiree{% endblock %}

{% block body %}
    <h1>Soiree</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ soiree.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ soiree.titre }}</td>
            </tr>
            <tr>
                <th>Datesoiree</th>
                <td>{{ soiree.datesoiree ? soiree.datesoiree|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Datecreation</th>
                <td>{{ soiree.datecreation ? soiree.datecreation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ soiree.statut }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_soiree_index') }}">back to list</a>

    <a href="{{ path('app_soiree_edit', {'id': soiree.id}) }}">edit</a>

    {{ include('soiree/_delete_form.html.twig') }}
{% endblock %}
