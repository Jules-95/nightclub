{% extends 'base.html.twig' %}

{% block title %}{{ soiree.titre }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-xl shadow">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">{{ soiree.titre }}</h1>
        {# Lien retour vers la liste #}
        <a href="{{ path('app_soiree_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">
            ← Retour à la liste
        </a>
    </div>

    {# Fiche détail de la soirée #}
    <div class="divide-y border rounded-xl overflow-hidden">
        <div class="flex px-4 py-3 bg-gray-50">
            <span class="w-40 font-semibold text-gray-600">Id</span>
            <span>{{ soiree.id }}</span>
        </div>
        <div class="flex px-4 py-3">
            <span class="w-40 font-semibold text-gray-600">Titre</span>
            <span>{{ soiree.titre }}</span>
        </div>
        <div class="flex px-4 py-3 bg-gray-50">
            <span class="w-40 font-semibold text-gray-600">Date soirée</span>
            <span>{{ soiree.datesoiree ? soiree.datesoiree|date('d/m/Y H:i') : '' }}</span>
        </div>
        <div class="flex px-4 py-3">
            <span class="w-40 font-semibold text-gray-600">Date création</span>
            <span>{{ soiree.datecreation ? soiree.datecreation|date('d/m/Y H:i') : '' }}</span>
        </div>
        <div class="flex px-4 py-3 bg-gray-50">
            <span class="w-40 font-semibold text-gray-600">Statut</span>
            <span>{{ soiree.statut }}</span>
        </div>
    </div>

    {# Actions #}
    <div class="flex gap-3 mt-6">
        <a href="{{ path('app_soiree_edit', {'id': soiree.id}) }}" class="bg-orange-500 text-white px-4 py-2 rounded hover:bg-orange-600">
            Modifier
        </a>
        {{ include('soiree/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}

