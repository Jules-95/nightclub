{% extends 'base.html.twig' %}

{% block title %}Modifier une soirée{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto mt-10 p-6 bg-white rounded-xl shadow">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Modifier une soirée</h1>
        {# Lien retour vers la liste #}
        <a href="{{ path('app_soiree_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">
            ← Retour à la liste
        </a>
    </div>

    {# Formulaire de modification #}
    {{ include('soiree/_form.html.twig', {'button_label': 'Modifier'}) }}

    {# Bouton de suppression #}
    <div class="mt-4 pt-4 border-t">
        {{ include('soiree/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}