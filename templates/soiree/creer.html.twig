{% extends 'base.html.twig' %}

{% block title %}Créer une soirée{% endblock %}

{% block body %}

{# Conteneur centré, fond blanc, coins arrondis, ombre #}
<div class="max-w-lg mx-auto mt-10 p-6 bg-white rounded-xl shadow">

    {# Titre principal, grand, gras, avec marge en bas #}
    <h1 class="text-2xl font-bold mb-6">Créer une soirée</h1>

    {# Désactive la validation HTML5 et Turbo, espace vertical entre les champs #}
    {{ form_start(form, { attr: { 'novalidate': 'novalidate', 'data-turbo': 'false', 'class': 'space-y-4' } }) }}

    {# Erreurs globales du formulaire en rouge #}
    <div class="form-error text-red-500">
        {{ form_errors(form) }}
    </div>

    {# Champ titre : empilé verticalement + gap #}
    <div class="flex flex-col gap-1">
        {# Label en semi-gras #}
        {{ form_label(form.titre, 'Titre', { label_attr: { class: 'font-semibold' } }) }}
        {# Input pleine largeur, bordure, coins arrondis, padding #}
        {{ form_widget(form.titre, { attr: { class: 'w-full border rounded px-3 py-2' } }) }}
        {# Erreur spécifique au champ, rouge, petit texte #}
        <div class="text-red-500 text-sm">{{ form_errors(form.titre) }}</div>
    </div>

    {# Champ date : même structure que titre #}
    <div class="flex flex-col gap-1">
        {{ form_label(form.datesoiree, 'Date de la soirée', { label_attr: { class: 'font-semibold' } }) }}
        {{ form_widget(form.datesoiree, { attr: { class: 'w-full border rounded px-3 py-2' } }) }}
        <div class="text-red-500 text-sm">{{ form_errors(form.datesoiree) }}</div>
    </div>

    {# Champ statut : même structure que titre #}
    <div class="flex flex-col gap-1">
        {{ form_label(form.statut, 'Statut', { label_attr: { class: 'font-semibold' } }) }}
        {{ form_widget(form.statut, { attr: { class: 'w-full border rounded px-3 py-2' } }) }}
        <div class="text-red-500 text-sm">{{ form_errors(form.statut) }}</div>
    </div>

    {# Bouton submit : bleu, texte blanc, s'assombrit au survol #}
    <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer">
        Créer la soirée
    </button>

    {{ form_end(form) }}
</div>
{% endblock %}