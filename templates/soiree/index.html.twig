{% extends 'base.html.twig' %}

{% block title %}Soiree index{% endblock %}

{% block body %}
    <h1>Soiree index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Datesoiree</th>
                <th>Datecreation</th>
                <th>Statut</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for soiree in soirees %}
            <tr>
                <td>{{ soiree.id }}</td>
                <td>{{ soiree.titre }}</td>
                <td>{{ soiree.datesoiree ? soiree.datesoiree|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ soiree.datecreation ? soiree.datecreation|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ soiree.statut }}</td>
                <td>
                    <a href="{{ path('app_soiree_show', {'id': soiree.id}) }}">show</a>
                    <a href="{{ path('app_soiree_edit', {'id': soiree.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_soiree_new') }}">Create new</a>
{% endblock %}
