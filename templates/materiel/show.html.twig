{% extends 'base.html.twig' %}

{% block title %}{{ materiel.nom }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-xl shadow">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">{{ materiel.nom }}</h1>
        {# Lien retour vers la liste #}
        <a href="{{ path('app_materiel_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">
            ← Retour à la liste
        </a>
    </div>

    {# Fiche détail du matériel #}
    <div class="divide-y border rounded-xl overflow-hidden">
        <div class="flex px-4 py-3 bg-gray-50">
            <span class="w-40 font-semibold text-gray-600">Id</span>
            <span>{{ materiel.id }}</span>
        </div>
        <div class="flex px-4 py-3">
            <span class="w-40 font-semibold text-gray-600">Nom</span>
            <span>{{ materiel.nom }}</span>
        </div>
    </div>

    {# Actions #}
    <div class="flex gap-3 mt-6">
        <a href="{{ path('app_materiel_edit', {'id': materiel.id}) }}" class="bg-orange-500 text-white px-4 py-2 rounded hover:bg-orange-600">
            Modifier
        </a>
        {{ include('materiel/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}