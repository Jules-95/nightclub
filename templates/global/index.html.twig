{% extends 'base.html.twig' %}

{% block title %}Hello GlobalController!{% endblock %}

{% block body %}
<div class="flex flex-col items-center">
    <h1 class="text-3xl font-bold text-gray-800 mb-4">{{ title }}</h1>

    <ul class="list-disc pl-5 text-gray-600 mb-6">
        <li>Ton controller <code>C:/Users/jlsmi/Desktop/symfony/nightclub/src/Controller/GlobalController.php</code></li>
        <li>Ton template <code>C:/Users/jlsmi/Desktop/symfony/nightclub/templates/global/index.html.twig</code></li>
    </ul>

    <div class="flex gap-4 mb-6">
        <a href="{{ path('contact') }}" class="bg-gray-900 text-white px-4 py-2 rounded hover:bg-gray-700">Contact</a>
        <a href="{{ path('app_global_apropos') }}" class="bg-gray-900 text-white px-4 py-2 rounded hover:bg-gray-700">À propos</a>
    </div>

    <img src="{{ asset('img/Fete.png') }}" class="rounded-lg shadow-md max-w-md">

    <div class="mt-8 w-full max-w-2xl">
        <h2 class="text-2xl font-bold mb-4">🎉 Prochaines soirées</h2>
        {% for soiree in soirees %}
        <div class="bg-white rounded-xl shadow p-4 mb-4">
            <h3 class="text-lg font-semibold">{{ soiree.titre }}</h3>
            <p class="text-gray-500">{{ soiree.datesoiree|date('d/m/Y H:i') }}</p>
        </div>
        {% else %}
            <p class="text-gray-500">Aucune soirée à venir.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
